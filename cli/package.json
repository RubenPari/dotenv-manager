{
  "name": "@rubenpari/dotenv-cli",
  "version": "1.0.2",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "dm": "./dist/index.js"
  },
  "files": [
    "dist/**",
    "README.md",
    "LICENSE*"
