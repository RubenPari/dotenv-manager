    "lint": "eslint src/"
  },
  "dependencies": {
    "@rubenpari/dotenv-cli-shared": "^1.0.1",
    "commander": "^12.1.0",
    "inquirer": "^12.0.0",
    "chalk": "^5.3.0",
    "ora": "^8.1.0",
    "axios": "^1.7.0",
    "open": "^10.1.0",
    "dotenv": "^16.4.0",
    "@types/dotenv": "^6.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "tsx": "^4.19.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "eslint": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "prettier": "^3.3.0"
