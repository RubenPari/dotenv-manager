NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://dotenv_user:dotenv_password@localhost:5432/dotenv_manager

JWT_SECRET=your-super-secret-key-min-32-chars-change-in-production
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=another-secret-min-32-chars-change-in-production
REFRESH_TOKEN_EXPIRES_IN=30d

MASTER_KEY_PEPPER=random-server-side-pepper-32-chars-change-in-production
MASTER_KEY_SALT=dotenv-manager-salt-change-in-production

CLIENT_URL=http://localhost:4200

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=10
